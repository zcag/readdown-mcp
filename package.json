{
  "name": "readdown-mcp",
  "version": "0.1.0",
  "description": "MCP server for converting web pages to clean LLM-optimized Markdown. Lightweight — no browser needed.",
  "type": "module",
  "bin": {
    "readdown-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "html-to-markdown",
    "web-scraping",
    "llm",
    "ai",
    "readability",
    "content-extraction"
  ],
  "license": "MIT",
  "author": "zcag",
  "repository": {
    "type": "git",
    "url": "https://github.com/zcag/readdown-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "readdown": "github:zcag/readdown",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  }
}
